				fireHitRemote(atm.Name,false)
	
				task.wait(0.35)
			end
	
			for i = 1,10 do
				if not running then
					break
				end
	
				fireCollectRemote()
	
				task.wait(0.2)
			end
	
			task.wait(0.1)
		end
	
		stopTeleportLoop()
	end
	
	local function processCashier(cashier)
		if not HRP then
			return
		end
	
		makeUncollidable(cashier)
	
		currentTarget = cashier
	
		startTeleportLoop()
	
		local attempts = 0
	
		while running and cashierIsTarget(cashier) and attempts < 10 do
