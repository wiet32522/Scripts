	local function processATM(atm)
		if not HRP then
			return
		end
	
		makeUncollidable(atm)
	
		currentTarget = atm
	
		startTeleportLoop()
	
		local attempts = 0
	
		while running and screenIsTarget(atm) and attempts < 10 do
			attempts = attempts + 1
	
			HRP.CFrame = atm:GetPivot() * CFrame.new(0,-2,0)
	
